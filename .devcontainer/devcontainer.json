{
  "name": "Prestamo Renovacion MLOps",
  "image": "mcr.microsoft.com/devcontainers/python:3.10",

  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },

  "postCreateCommand": "pip install -r requirements.txt && cp .env.example .env.preprod",

  "forwardPorts": [8000, 5000],

  "portsAttributes": {
    "8000": {
      "label": "API FastAPI",
      "onAutoForward": "openBrowser"
    },
    "5000": {
      "label": "MLflow UI",
      "onAutoForward": "notify"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "mtxr.sqltools"
      ]
    }
  }
}
