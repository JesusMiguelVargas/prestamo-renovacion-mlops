# Copia este archivo a .env.preprod y completa los valores
# NUNCA subas .env.preprod a Git

ENV=preprod
DEBUG=False
LOG_LEVEL=INFO

# API
API_PORT=8000
API_WORKERS=1

# MLflow
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=prestamo-renovacion-mlops

# Modelo
MODEL_PATH=artifacts/model.pkl
RECALL_MIN=0.55

# Seguridad (cambia esto en preprod real)
SECRET_KEY=cambia-esto-antes-de-usar
